# Environment Configuration

# Server
NODE_ENV=development
PORT=3000
API_VERSION=v1

# ASR Provider Configuration
# Supported: google
ASR_PROVIDER=google

# Vertex AI / Gemini (#134)
# Set LLM_PROVIDER=vertex to activate Gemini backend
GOOGLE_APPLICATION_CREDENTIALS=/srv/silverleaf/car-assistant-pro/server/credentials/vertex-sa.json
LLM_PROVIDER=vertex
GOOGLE_CLOUD_PROJECT=assistant-pro-490416
VERTEX_AI_LOCATION=us-central1
VERTEX_AI_MODEL_FREE=gemini-2.5-flash
VERTEX_AI_MODEL_PREMIUM=gemini-2.5-pro

# DeepSeek-V3.1 via Vertex AI Model Garden (#145)
# Business mode uses DeepSeek; falls back to Gemini if not set.
# Requires NVIDIA H100 GPU quota in Vertex AI — leave commented until approved.
DEEPSEEK_MODEL=google/deepseek-ai/deepseek-v3

# Claude Haiku via Vertex AI Anthropic Partner Models (#150)
# Kids mode uses Claude Haiku; falls back to Gemini if not set.
# Requires Anthropic model enabled in Vertex AI Model Garden.
ANTHROPIC_MODEL=claude-haiku-4-5

# TTS Provider Configuration
# Supported: google
TTS_PROVIDER=google

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS_ASR=100
RATE_LIMIT_MAX_REQUESTS_CHAT=200
RATE_LIMIT_MAX_REQUESTS_TTS=100
RATE_LIMIT_MAX_REQUESTS_VOICE=50
TTS_SPEAKING_RATE=0.9

# Voice persona — Sylex (#154)
# Wake-word detected client-side only (Porcupine / on-device model)
# This value is informational — used for logging/analytics on the server
VOICE_WAKE_WORD=hey sylex
VOICE_PERSONA_NAME=Sylex

# File Upload Limits
MAX_AUDIO_SIZE_MB=10
MAX_AUDIO_DURATION_SECONDS=60

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# CORS
CORS_ORIGIN=*

# Security
JWT_SECRET=your_jwt_secret_here

# Firebase Admin SDK (#125) — used for Auth custom claims
# Can reuse GOOGLE_APPLICATION_CREDENTIALS if it has Firebase Admin permissions
FIREBASE_SERVICE_ACCOUNT=./credentials/firebase-sa.json

# Apple App Store Server API (#125)
APPLE_BUNDLE_ID=studio.silverleaf.carassistantpro
APPLE_ISSUER_ID=<from App Store Connect>
APPLE_KEY_ID=<from App Store Connect>
APPLE_PRIVATE_KEY=<contents of .p8 file, newlines as \n>
APPLE_ENVIRONMENT=production

# Google Play Developer API (#125)
GOOGLE_PLAY_PACKAGE_NAME=studio.silverleaf.carassistantpro
GOOGLE_PLAY_SA_JSON=/srv/silverleaf/car-assistant-pro/server/credentials/play-sa.json

# Google Maps — Car Assistant (#122)
# Enable: GCP Console → APIs & Services → Routes API + Places API + Geocoding API
# GOOGLE_MAPS_API_KEY=your_key_here

# Alibaba Cloud (for hackathon integration proof)
ALIBABA_ACCESS_KEY_ID=your_alibaba_access_key_id_here
ALIBABA_ACCESS_KEY_SECRET=your_alibaba_access_key_secret_here
