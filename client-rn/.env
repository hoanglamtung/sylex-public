# Local environment overrides for Vite web client
# Do NOT commit secrets to this file!
#
# To override the web UI plan mode for QA/testing, set one of:
# VITE_WEB_TEST_PLAN=auto   # (default: uses app logic)
# VITE_WEB_TEST_PLAN=free   # (forces free-mode UI)
# VITE_WEB_TEST_PLAN=pro    # (forces pro-mode UI)
VITE_WEB_TEST_PLAN=free
