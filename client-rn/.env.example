# Web API base URL for Vite web target
# Used by web/orchestration.ts via import.meta.env.VITE_API_BASE_URL
#
# Local development example:
# VITE_API_BASE_URL=http://localhost:3000
#
# Production example:
# VITE_API_BASE_URL=https://api.car-assistant-pro.silverleaf.studio

VITE_API_BASE_URL=https://api.car-assistant-pro.silverleaf.studio

# Web UI test override for subscription mode
# Values: auto | free | pro
# - auto: uses app default behavior (currently treated as free in web until auth wiring is added)
# - free: forces free-mode UI
# - pro: forces pro-mode UI
VITE_WEB_TEST_PLAN=pro
